<!DOCTYPE log4j:configuration SYSTEM "log4j.dtd">
<Configuration status="ERROR">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
        </Console>
    </Appenders>
    <Loggers>
        <Root level="info">
            <AppenderRef ref="Console"/>
        </Root>
        <Logger name="org.sv.flexobject.arrow.store.MemoryStore" level="debug">
        </Logger>
        <Logger name="org.sv.flexobject.arrow.streaming.ArrowStreamSink" level="debug">
        </Logger>
        <Logger name="org.sv.flexobject.arrow.streaming.ArrowStreamSource" level="debug">
        </Logger>
    </Loggers>
</Configuration>